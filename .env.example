# ======== Anthropic ========
ANTHROPIC_API_KEY=sk-ant-...

# ======== Google / Gmail OAuth ========
# Create an OAuth 2.0 Client (type: Desktop app) in Google Cloud Console.
# Enable the Gmail API on the same project.
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=...
# Obtain by running `npm run get-token` locally and pasting the value it prints.
GOOGLE_REFRESH_TOKEN=...

# ======== Sender identity ========
# Must match the Gmail account that authorized the OAuth consent above.
EVALUATOR_FROM_EMAIL=jobs@yourdomain.com
EVALUATOR_FROM_NAME=Hiring Team

# ======== Cron protection ========
# Any long random string. Required when calling /api/cron/poll from outside Vercel.
CRON_SECRET=change-me-to-a-long-random-string

# ======== Optional ========
# A GitHub personal access token (read-only / public is enough). Lifts rate limit from 60/hr to 5000/hr.
GITHUB_TOKEN=
# Label prefix used to track application state in Gmail. Default: evaluator
APPLICATION_LABEL_PREFIX=evaluator
# Max applications to process per cron tick (Vercel function time budget).
MAX_PER_TICK=3

# Demo / staging allowlist. If set, only mail with this string in the To: header
# is processed. Use a dedicated address like apply@yourdomain.com so the agent
# ignores the rest of a shared inbox during a live demo.
EVALUATOR_ALLOWED_TO=

# Upstash Redis (Vercel Marketplace integration auto-injects these in production).
# Local dev: paste from the Vercel project's "Storage" tab.
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
